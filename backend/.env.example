PORT=3001
NODE_ENV=development

# ── Veritabanı ──────────────────────────────────────────────
# Docker compose'da DB_HOST=db olarak override edilir
DB_HOST=localhost
DB_PORT=5432
DB_USER=renel
DB_PASS=guclu_bir_sifre_yaz

DB_NAME=renel_enerji

# Şema migration'larla kurulur ve güncellenir; uygulama açılışında bekleyen
# migration'lar otomatik çalışır (migrationsRun). Elle çalıştırmak için:
#   npm run migration:run

# ── JWT ─────────────────────────────────────────────────────
# ZORUNLU — en az 32 karakter rastgele string
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── Admin ───────────────────────────────────────────────────
ADMIN_USERNAME=admin

# ZORUNLU — bcrypt hash, plain text şifre ASLA kullanılmaz
# Hash üretmek için: node -e "require('bcrypt').hash('SIFREN',10).then(console.log)"
ADMIN_PASSWORD_HASH=

# ── CORS ────────────────────────────────────────────────────
# ZORUNLU — frontend domain (wildcard * kabul edilmez)
FRONTEND_URL=http://localhost:5173
# Opsiyonel — virgüllü açık origin listesi; doluysa aynen kullanılır (www
# türetme yapılmaz), boşsa FRONTEND_URL'den www'lu varyant türetilir.
# Örnek: CORS_ORIGINS=https://www.renelenerji.com,https://renelenerji.com
CORS_ORIGINS=

# ── Redis ───────────────────────────────────────────────────
# ZORUNLU — en az 32 karakter rastgele string
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDIS_PASS=
# Docker compose'da redis://:${REDIS_PASS}@redis:6379 olarak override edilir
REDIS_URL=redis://:REDIS_PASS_BURAYA@localhost:6379

# ── Umami Analitik ──────────────────────────────────────────
# Umami kurulduktan sonra panel'den alınır
UMAMI_WEBSITE_ID=
# Umami admin şifresi (ilk girişte değiştir)
UMAMI_USER=admin
UMAMI_PASS=guclu_umami_sifresi
# Umami PostgreSQL şifresi
UMAMI_DB_PASS=guclu_umami_db_sifresi
# Umami uygulama gizli anahtarı — rastgele string
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UMAMI_APP_SECRET=

# ── Frontend Build ──────────────────────────────────────────
# Prodüksiyonda domain (örn: https://renelenerji.com)
# Aynı domain'den servis ediliyorsa boş bırakılabilir
VITE_API_URL=
# Umami script URL'si (örn: https://umami.renelenerji.com)
VITE_UMAMI_URL=

# ── OpenWeather ─────────────────────────────────────────────
# Dashboard hava durumu widget'ı için (opsiyonel)
OPENWEATHER_API_KEY=

# ── Instagram Graph API ─────────────────────────────────────
# Meta Developer Console → Uygulamanız → Instagram → Temel Ekran
INSTAGRAM_USER_ID=
# Meta Developer Console → Araçlar → Graph API Explorer → Token oluştur (60 gün, yenilenmesi gerekir)
INSTAGRAM_ACCESS_TOKEN=
# Meta Developer Console → Uygulamanız → Ayarlar → Temel → Uygulama gizli anahtarı
INSTAGRAM_APP_SECRET=
# Webhook aboneliği sırasında Meta'ya gönderilecek doğrulama tokeni — kendin belirle
# Üretmek için: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# ── Groq API ────────────────────────────────────────────────
# Amaç bazlı anahtar listeleri: virgüllü, sıra = deneme önceliği.
# Chatbot ve Instagram parse ayrı liste kullanır ki rate limitleri birbirini etkilemesin.
# Örnek: GROQ_CHAT_KEYS=gsk_chatbot,gsk_yedek  GROQ_PARSE_KEYS=gsk_parse,gsk_yedek
GROQ_CHAT_KEYS=
GROQ_PARSE_KEYS=
# ESKİ DÜZEN (hâlâ çalışır): yeni listeler boşsa aşağıdakilerden türetilir —
# chatbot KEY_3'ü (yoksa KEY'i), parse KEY'i kullanır, KEY_2 ortak yedek.
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
# Chatbot'un günlük toplam Groq istek üst sınırı (devre kesici; boşsa 1000)
# Aşılırsa chatbot sabit mesaja düşer, Instagram parse etkilenmez
GROQ_DAILY_LIMIT=1000

# ── Sentry (Hata İzleme) ────────────────────────────────────
# sentry.io üzerinde proje oluşturduktan sonra DSN'i buraya yapıştır
# Boş bırakılırsa Sentry devre dışı kalır
SENTRY_DSN=
APP_ENCRYPTION_KEY=  # openssl rand -hex 32 ile uret — TOTP secret sifrelemesi icin zorunlu
