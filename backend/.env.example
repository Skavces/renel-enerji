PORT=3001
NODE_ENV=development

# ── Veritabanı ──────────────────────────────────────────────
# Docker compose'da DB_HOST=db olarak override edilir
DB_HOST=localhost
DB_PORT=5432
DB_USER=renel
DB_PASS=guclu_bir_sifre_yaz

DB_NAME=renel_enerji

# İLK KURULUMDA true yap, tablolar oluştuktan sonra false'a al
DB_SYNC=false

# ── JWT ─────────────────────────────────────────────────────
# ZORUNLU — en az 32 karakter rastgele string
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── Admin ───────────────────────────────────────────────────
ADMIN_USERNAME=admin

# ZORUNLU — bcrypt hash, plain text şifre ASLA kullanılmaz
# Hash üretmek için: node -e "require('bcrypt').hash('SIFREN',10).then(console.log)"
ADMIN_PASSWORD_HASH=

# ── CORS ────────────────────────────────────────────────────
# ZORUNLU — frontend domain (wildcard * kabul edilmez)
FRONTEND_URL=http://localhost:5173

# ── Redis ───────────────────────────────────────────────────
# Docker compose'da redis://redis:6379 olarak override edilir
REDIS_URL=redis://localhost:6379

# ── Umami Analitik ──────────────────────────────────────────
# Umami kurulduktan sonra panel'den alınır
UMAMI_WEBSITE_ID=
# Umami admin şifresi (ilk girişte değiştir)
UMAMI_USER=admin
UMAMI_PASS=guclu_umami_sifresi
# Umami PostgreSQL şifresi
UMAMI_DB_PASS=guclu_umami_db_sifresi
# Umami uygulama gizli anahtarı — rastgele string
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UMAMI_APP_SECRET=

# ── Frontend Build ──────────────────────────────────────────
# Prodüksiyonda domain (örn: https://renelenerji.com)
# Aynı domain'den servis ediliyorsa boş bırakılabilir
VITE_API_URL=
# Umami script URL'si (örn: https://umami.renelenerji.com)
VITE_UMAMI_URL=

# ── OpenWeather ─────────────────────────────────────────────
# Dashboard hava durumu widget'ı için (opsiyonel)
OPENWEATHER_API_KEY=
