PORT=3001
NODE_ENV=development

# Docker compose DB_HOST=db olarak override eder, local dev için localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=renel
DB_PASS=renel_pass
DB_NAME=renel_enerji

# ZORUNLU — en az 32 karakter rastgele string
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ZORUNLU — admin kullanıcı adı
ADMIN_USERNAME=admin

# ZORUNLU — bcrypt hash, plain text şifre ASLA kullanılmaz
# Hash üretmek için: node -e "require('bcrypt').hash('SIFREN',10).then(console.log)"
ADMIN_PASSWORD_HASH=

# ZORUNLU — frontend domain (wildcard * kabul edilmez)
FRONTEND_URL=http://localhost:5173
