{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": {
          "allowJs": true
        }
      }
    ]
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!(htmlparser2|entities|domhandler|domutils|dom-serializer|domelementtype|file-type|strtok3|token-types|peek-readable|uint8array-extras|@tokenizer|@borewit)/)"
  ],
  "setupFiles": ["<rootDir>/setup-e2e.ts"],
  "testEnvironment": "node",
  "testTimeout": 30000
}
